---
---

<section class="relative py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="relative rounded-3xl overflow-hidden">
      <!-- Gradient background -->
      <div class="absolute inset-0 bg-gradient-to-br from-flame via-magenta to-indigo opacity-90"></div>
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,.2) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.2) 1px, transparent 1px); background-size: 48px 48px;"></div>

      <div class="relative px-8 py-20 md:px-16 md:py-28 text-center">
        <h2 class="text-4xl md:text-6xl font-black tracking-tight text-white mb-6">
          Stop fighting your tools.<br />Start shipping.
        </h2>
        <p class="text-xl text-white/80 max-w-2xl mx-auto mb-12">
          Pulse is open source, free, and ready for your next project.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/docs/installation"
            class="px-8 py-4 rounded-2xl bg-white text-surface font-bold text-lg hover:bg-white/90 transition-colors"
          >
            Install Pulse
          </a>
          <a
            href="https://github.com/seventwo-studio/pulse"
            class="px-8 py-4 rounded-2xl border-2 border-white/30 text-white font-bold text-lg hover:bg-white/10 transition-colors"
          >
            Star on GitHub
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
