---
const commands = [
  { cmd: "pulse init", desc: "Create a repository", flag: "--remote <url>" },
  { cmd: "pulse workspace create", desc: "Start working", flag: "--intent --scope" },
  { cmd: "pulse commit", desc: "Save changes", flag: "-m -w <files>" },
  { cmd: "pulse merge", desc: "Close a workspace", flag: "<workspace>" },
  { cmd: "pulse status", desc: "See repo state", flag: "" },
  { cmd: "pulse log", desc: "Trunk history", flag: "--author --limit" },
  { cmd: "pulse files", desc: "List trunk files", flag: "" },
  { cmd: "pulse show", desc: "Cat a file", flag: "<path>" },
  { cmd: "pulse diff", desc: "Compare snapshots", flag: "<a> <b>" },
];
---

<section class="relative py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-4xl md:text-5xl font-black tracking-tight mb-6">
          Nine commands.<br />
          <span class="bg-gradient-to-r from-flame to-magenta bg-clip-text text-transparent">Zero complexity.</span>
        </h2>
        <p class="text-xl text-text-secondary leading-relaxed mb-8">
          No staging area. No detached HEAD. No reflog rescue missions.
          Pulse's entire interface fits on a napkin.
        </p>
        <a href="/docs/cli/init" class="inline-flex items-center gap-2 text-magenta font-semibold hover:underline">
          Read the CLI reference
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      <div class="rounded-2xl border border-white/5 bg-surface-raised overflow-hidden">
        <div class="flex items-center gap-2 px-5 py-3 border-b border-white/5">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
            <div class="w-3 h-3 rounded-full bg-white/10"></div>
          </div>
          <span class="text-xs text-text-secondary ml-2 font-mono">pulse --help</span>
        </div>
        <div class="p-5 font-mono text-sm space-y-0">
          {commands.map((c) => (
            <div class="flex items-baseline gap-4 py-2 px-3 -mx-3 rounded-lg hover:bg-white/3 transition-colors">
              <span class="text-cyan whitespace-nowrap shrink-0">{c.cmd}</span>
              <span class="text-text-secondary text-xs truncate">{c.desc}</span>
              {c.flag && <span class="text-text-secondary/50 text-xs ml-auto whitespace-nowrap hidden sm:inline">{c.flag}</span>}
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
